{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 450,
  "background": null,
  "data": {
    "url": "data/streamgraph_population_growth.csv"
  },
  "mark": {
    "type": "area",
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "axis": {
        "title": null,
        "labelAngle": 0
      }
    },
    "y": {
      "field": "Value",
      "type": "quantitative",
      "stack": true,
      "axis": {
        "title": "People",
        "format": "d"
      }
    },
    "color": {
      "field": "Component",
      "type": "nominal",
      "scale": {
        "domain": [
          "Natural increase",
          "Net overseas migration"
        ],
        "range": [
          "#2A9D72",
          "#E05C2A"
        ]
      },
      "legend": {
        "title": null,
        "orient": "bottom"
      }
    },
    "order": {
      "field": "Component",
      "sort": "ascending"
    },
    "tooltip": [
      {
        "field": "Year",
        "type": "ordinal"
      },
      {
        "field": "Component",
        "type": "nominal"
      },
      {
        "field": "Value",
        "type": "quantitative",
        "format": "d"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#3b516d",
      "domain": false,
      "labelColor": "#f5f0e8",
      "titleColor": "#f5f0e8",
      "labelFont": "Barlow",
      "titleFont": "Barlow"
    },
    "legend": {
      "labelColor": "#f5f0e8",
      "titleColor": "#f5f0e8",
      "labelFont": "Barlow",
      "titleFont": "Barlow"
    }
  },
  "title": {
    "text": "Components of Population Change",
    "subtitle": "Natural increase vs. net overseas migration, 2015\u20132025",
    "fontSize": 13,
    "subtitleFontSize": 11,
    "color": "#f5f0e8",
    "subtitleColor": "#c8bfad",
    "anchor": "start",
    "offset": 10,
    "font": "Cormorant Garamond",
    "subtitleFont": "Barlow"
  }
}