{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 500,
  "background": null,
  "data": {
    "url": "data/state_growth_all_years.csv"
  },
  "transform": [
    {
      "window": [
        {
          "op": "rank",
          "as": "Rank"
        }
      ],
      "sort": [
        {
          "field": "Growth",
          "order": "descending"
        }
      ],
      "groupby": [
        "Year"
      ]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "axis": {
            "title": null,
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Rank",
          "type": "ordinal",
          "sort": "ascending",
          "axis": {
            "title": "Growth rank",
            "values": [
              1,
              2,
              3,
              4,
              5,
              6,
              7,
              8
            ]
          }
        },
        "color": {
          "field": "State",
          "type": "nominal",
          "scale": {
            "domain": [
              "NSW",
              "VIC",
              "QLD",
              "WA",
              "SA",
              "TAS",
              "ACT",
              "NT"
            ],
            "range": [
              "#1B6CA8",
              "#E05C2A",
              "#2A9D72",
              "#D4A017",
              "#9B3A8C",
              "#3AABCC",
              "#C94040",
              "#6B8F71"
            ]
          },
          "legend": {
            "title": null,
            "orient": "bottom"
          }
        },
        "tooltip": [
          {
            "field": "State",
            "type": "nominal"
          },
          {
            "field": "Year",
            "type": "ordinal"
          },
          {
            "field": "Growth",
            "type": "quantitative",
            "format": ".2%",
            "title": "Growth rate"
          },
          {
            "field": "Rank",
            "type": "ordinal"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Year == 2025"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 12,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal"
        },
        "y": {
          "field": "Rank",
          "type": "ordinal"
        },
        "text": {
          "field": "State"
        },
        "color": {
          "field": "State",
          "type": "nominal",
          "scale": {
            "domain": [
              "NSW",
              "VIC",
              "QLD",
              "WA",
              "SA",
              "TAS",
              "ACT",
              "NT"
            ],
            "range": [
              "#1B6CA8",
              "#E05C2A",
              "#2A9D72",
              "#D4A017",
              "#9B3A8C",
              "#3AABCC",
              "#C94040",
              "#6B8F71"
            ]
          }
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": false,
      "labelColor": "#f5f0e8",
      "titleColor": "#f5f0e8",
      "labelFont": "Barlow",
      "titleFont": "Barlow"
    },
    "legend": {
      "labelColor": "#f5f0e8",
      "titleColor": "#f5f0e8",
      "labelFont": "Barlow",
      "titleFont": "Barlow"
    }
  },
  "title": {
    "text": "The State Growth Rankings, Year by Year",
    "subtitle": "Rank 1 = fastest growing \u2014 line crossings are the story",
    "fontSize": 13,
    "subtitleFontSize": 11,
    "color": "#f5f0e8",
    "subtitleColor": "#c8bfad",
    "anchor": "start",
    "offset": 10,
    "font": "Cormorant Garamond",
    "subtitleFont": "Barlow"
  }
}