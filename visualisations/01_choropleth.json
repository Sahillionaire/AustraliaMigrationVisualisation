{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 500,
  "projection": {
    "type": "mercator",
    "center": [
      133,
      -28
    ],
    "scale": 700
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "padding": {
    "left": 0,
    "right": 0,
    "top": 0,
    "bottom": 0
  },
  "layer": [
    {
      "data": {
        "url": "data/AUS_MAP.json",
        "format": {
          "type": "topojson",
          "feature": "STE_2021_AUST_GDA2020"
        }
      },
      "transform": [
        {
          "lookup": "properties.STE_NAME21",
          "from": {
            "data": {
              "url": "data/state_growth_chloropleth.csv"
            },
            "key": "State",
            "fields": [
              "Growth"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "color": {
          "field": "Growth",
          "type": "quantitative",
          "scale": {
            "domain": [
              8,
              23
            ],
            "scheme": "blues"
          },
          "legend": {
            "title": "Population Growth (%)",
            "orient": "bottom-left",
            "gradientLength": 180,
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          {
            "field": "properties.STE_NAME21",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Growth",
            "type": "quantitative",
            "title": "Growth (%)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/state_growth_chloropleth.csv"
      },
      "transform": [
        {
          "lookup": "State",
          "from": {
            "data": {
              "values": [
                {
                  "State": "Australian Capital Territory",
                  "lat": -35.47,
                  "lon": 152.01,
                  "abbr": "ACT"
                },
                {
                  "State": "New South Wales",
                  "lat": -32.0,
                  "lon": 146.5,
                  "abbr": "NSW"
                },
                {
                  "State": "Northern Territory",
                  "lat": -19.5,
                  "lon": 133.0,
                  "abbr": "NT"
                },
                {
                  "State": "Queensland",
                  "lat": -22.0,
                  "lon": 144.0,
                  "abbr": "QLD"
                },
                {
                  "State": "South Australia",
                  "lat": -30.0,
                  "lon": 135.0,
                  "abbr": "SA"
                },
                {
                  "State": "Tasmania",
                  "lat": -42.0,
                  "lon": 146.5,
                  "abbr": "TAS"
                },
                {
                  "State": "Victoria",
                  "lat": -36.45,
                  "lon": 144.5,
                  "abbr": "VIC"
                },
                {
                  "State": "Western Australia",
                  "lat": -25.0,
                  "lon": 121.0,
                  "abbr": "WA"
                }
              ]
            },
            "key": "State",
            "fields": [
              "lat",
              "lon",
              "abbr"
            ]
          }
        },
        {
          "calculate": "datum.abbr + '\\n' + format(datum.Growth, '.1f') + '%'",
          "as": "label"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontWeight": "bold",
        "align": "center",
        "baseline": "middle",
        "lineBreak": "\n"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        },
        "color": {
          "value": "#000000"
        }
      }
    }
  ],
  "config": {
    "background": "#f9f9f9",
    "view": {
      "stroke": "transparent"
    },
    "font": "Georgia"
  }
}