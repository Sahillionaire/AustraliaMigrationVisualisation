{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": null,
  "columns": 4,
  "data": {
    "url": "data/state_growth_all_years.csv"
  },
  "facet": {
    "field": "State",
    "type": "nominal",
    "sort": [
      "NSW",
      "VIC",
      "QLD",
      "WA",
      "SA",
      "TAS",
      "ACT",
      "NT"
    ],
    "header": {
      "title": null,
      "labelColor": "#f5f0e8",
      "labelFont": "Barlow",
      "labelFontSize": 13,
      "labelFontWeight": "bold"
    }
  },
  "spec": {
    "width": 250,
    "height": 150,
    "mark": {
      "type": "line",
      "strokeWidth": 3,
      "interpolate": "monotone",
      "point": {
        "filled": true,
        "size": 28
      }
    },
    "encoding": {
      "x": {
        "field": "Year",
        "type": "ordinal",
        "axis": {
          "title": null,
          "labelAngle": 0,
          "labelFontSize": 9,
          "labelExpr": "datum.value == 2016 || datum.value == 2025 ? datum.value : ''"
        }
      },
      "y": {
        "field": "Population",
        "type": "quantitative",
        "scale": {
          "zero": false
        },
        "axis": {
          "title": null,
          "format": "~s",
          "labelFontSize": 9
        }
      },
      "color": {
        "field": "State",
        "type": "nominal",
        "scale": {
          "domain": [
            "NSW",
            "VIC",
            "QLD",
            "WA",
            "SA",
            "TAS",
            "ACT",
            "NT"
          ],
          "range": [
            "#1B6CA8",
            "#E05C2A",
            "#2A9D72",
            "#D4A017",
            "#9B3A8C",
            "#3AABCC",
            "#C94040",
            "#6B8F71"
          ]
        },
        "legend": null
      },
      "tooltip": [
        {
          "field": "State",
          "type": "nominal"
        },
        {
          "field": "Year",
          "type": "ordinal"
        },
        {
          "field": "Population",
          "type": "quantitative",
          "format": ","
        },
        {
          "field": "Growth",
          "type": "quantitative",
          "format": ".2%",
          "title": "Growth rate"
        }
      ]
    }
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": false,
      "domain": false,
      "tickColor": "#c8bfad",
      "labelColor": "#f5f0e8",
      "titleColor": "#f5f0e8",
      "labelFont": "Barlow",
      "titleFont": "Barlow"
    }
  },
  "title": {
    "text": "Each State's Population Trajectory",
    "subtitle": "One panel per state, same axis scale throughout",
    "fontSize": 13,
    "subtitleFontSize": 11,
    "color": "#f5f0e8",
    "subtitleColor": "#c8bfad",
    "anchor": "start",
    "offset": 10,
    "font": "Cormorant Garamond",
    "subtitleFont": "Barlow"
  }
}