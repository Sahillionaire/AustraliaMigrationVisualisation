{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "background": null,
  "data": {
    "url": "data/source_country_migration.csv"
  },
  "transform": [
    {
      "filter": "datum.Migrants > 0"
    }
  ],
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "axis": {
        "title": null,
        "labelAngle": 0
      }
    },
    "y": {
      "aggregate": "sum",
      "field": "Migrants",
      "type": "quantitative",
      "stack": "normalize",
      "axis": {
        "title": "Share of migrants",
        "format": "%"
      }
    },
    "color": {
      "field": "Country",
      "type": "nominal",
      "legend": {
        "title": null,
        "orient": "bottom",
        "columns": 4
      },
      "scale": {
        "domain": [
          "Afghanistan",
          "Bangladesh",
          "China",
          "Hong Kong",
          "India",
          "Indonesia",
          "Iran",
          "Ireland",
          "Nepal",
          "New Zealand",
          "Pakistan",
          "Philippines",
          "South Africa",
          "Sri Lanka",
          "UK",
          "Vietnam"
        ],
        "range": [
          "#4E79A7",
          "#F28E2B",
          "#E15759",
          "#76B7B2",
          "#59A14F",
          "#EDC948",
          "#B07AA1",
          "#FF9DA7",
          "#9C755F",
          "#BAB0AC",
          "#D37295",
          "#FABFD2",
          "#8CD17D",
          "#86BCB6",
          "#499894",
          "#F1CE63"
        ]
      }
    },
    "tooltip": [
      {
        "field": "Year",
        "type": "ordinal"
      },
      {
        "field": "Country",
        "type": "nominal"
      },
      {
        "aggregate": "sum",
        "field": "Migrants",
        "type": "quantitative",
        "format": ","
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": false,
      "labelColor": "#2a3545",
      "titleColor": "#2a3545",
      "labelFont": "Barlow",
      "titleFont": "Barlow"
    },
    "legend": {
      "labelFont": "Barlow",
      "titleFont": "Barlow"
    }
  },
  "title": {
    "text": "Source Country Mix Over Time",
    "subtitle": "Top source countries as % of annual arrivals",
    "fontSize": 13,
    "subtitleFontSize": 11,
    "color": "#2a3545",
    "subtitleColor": "#666666",
    "anchor": "start",
    "offset": 10,
    "font": "Cormorant Garamond",
    "subtitleFont": "Barlow"
  }
}